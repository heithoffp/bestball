{
  "manifest_version": 3,
  "name": "Best Ball Exposures",
  "version": "1.0.7",
  "description": "Portfolio-aware draft context for best-ball fantasy football",
  "permissions": [
    "storage",
    "identity"
  ],
  "host_permissions": [
    "https://app.underdogfantasy.com/*",
    "https://api.underdogfantasy.com/*",
    "https://stats.underdogfantasy.com/*",
    "https://app.underdogsports.com/*",
    "https://api.underdogsports.com/*",
    "https://stats.underdogsports.com/*",
    "https://www.draftkings.com/*",
    "https://api.draftkings.com/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "bbe-extension@bestballexposures.com",
      "strict_min_version": "128.0",
      "update_url": "https://bestballexposures.com/updates.json",
      "data_collection_permissions": {
        "required": [
          "authenticationInfo",
          "personallyIdentifyingInfo",
          "websiteContent"
        ]
      }
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://app.underdogfantasy.com/*",
        "https://app.underdogsports.com/*"
      ],
      "js": [
        "src/injected/underdog-bridge.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://app.underdogfantasy.com/*",
        "https://app.underdogsports.com/*"
      ],
      "js": [
        "src/content/content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.draftkings.com/*"
      ],
      "js": [
        "src/content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Best Ball Exposures"
  },
  "homepage_url": "https://bestballexposures.com/privacy.html",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "externally_connectable": {
    "matches": [
      "https://bestballexposures.com/*",
      "https://www.bestballexposures.com/*",
      "http://localhost:*/*"
    ]
  },
  "web_accessible_resources": [
    {
      "matches": [
        "https://app.underdogfantasy.com/*",
        "https://app.underdogsports.com/*",
        "https://www.draftkings.com/*"
      ],
      "resources": []
    }
  ]
}
