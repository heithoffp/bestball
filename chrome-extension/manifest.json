{
  "manifest_version": 3,
  "name": "Best Ball Manager",
  "version": "0.1.0",
  "description": "Portfolio-aware draft context for best-ball fantasy football",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://app.underdogfantasy.com/*",
    "https://api.underdogfantasy.com/*",
    "https://stats.underdogfantasy.com/*",
    "https://www.draftkings.com/*",
    "https://api.draftkings.com/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://app.underdogfantasy.com/*"],
      "js": ["src/injected/underdog-bridge.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://app.underdogfantasy.com/*"],
      "js": ["src/content/content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.draftkings.com/*"],
      "js": ["src/content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Best Ball Manager"
  },
  "icons": {},
  "web_accessible_resources": [
    {
      "matches": [
        "https://app.underdogfantasy.com/*",
        "https://www.draftkings.com/*"
      ],
      "resources": []
    }
  ]
}
