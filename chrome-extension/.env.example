VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Release pipeline (TASK-215)
# Absolute path to the .crx signing private key (PEM, RSA 2048).
# This key MUST be backed up offline — losing it bricks auto-update for every installed user (ADR-005).
BBE_CRX_PRIVATE_KEY_PATH=/absolute/path/to/bbe-extension.pem

# Extension ID derived from the public key. Recorded once after first key generation;
# release script aborts if the produced CRX has a different ID (catches "wrong key" mistakes).
BBE_EXTENSION_ID=your-32-char-extension-id

# URL template for hosted .crx downloads. {version} is substituted at release time.
# Example: https://bestballexposures.com/extension/bestballexposures-extension-{version}.crx
BBE_CRX_DOWNLOAD_URL_TEMPLATE=https://bestballexposures.com/extension/bestballexposures-extension-{version}.crx

# Firefox signing (TASK-216)
# Generate at https://addons.mozilla.org/developers/addon/api/key/.
# Used by `npm run sign:firefox` to obtain a Mozilla-signed .xpi via web-ext sign --channel=unlisted.
# Per ADR-005, Firefox distribution uses unlisted self-distribution signing — no public AMO listing.
AMO_JWT_ISSUER=user:1234567:89
AMO_JWT_SECRET=your-amo-jwt-secret
