# Best Ball Portfolio Manager — Feedback Loops
# d2-render-layout: elk

# --- FL1: Draft-Analyze-Draft (Reinforcing, Active) ---
# The core value loop: draft -> upload -> analyze -> better next draft

FL1: FL1 Draft-Analyze-Draft\n(Reinforcing, Active) {
  style.fill: "#F0F8FF"
  style.stroke: "#4A90D9"
  style.font-size: 16

  R1: Drafter {
    style.fill: "#4A90D9"
    style.font-color: "#FFFFFF"
  }
  E1: Underdog {
    style.fill: "#E67E22"
    style.font-color: "#FFFFFF"
  }
  P1: Data Pipeline {
    style.fill: "#7B68EE"
    style.font-color: "#FFFFFF"
  }
  P3: Analytics Engine {
    style.fill: "#7B68EE"
    style.font-color: "#FFFFFF"
  }
  A3: Analytics UI {
    style.fill: "#2ECC71"
    style.font-color: "#FFFFFF"
  }

  R1 -> E1: Drafts
  E1 -> P1: Exports CSV
  P1 -> P3: Enriched data
  P3 -> A3: Renders insights
  A3 -> R1: Informs next draft
}

# --- FL2: ADP-Value Discovery (Reinforcing, Active) ---
