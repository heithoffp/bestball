# --- FL5: Portfolio Context Sync (Reinforcing, Active) ---
# Extension syncs entries -> Supabase -> overlay shows context during draft

FL5: FL5 Portfolio Context Sync\n(Reinforcing, Active) {
  style.fill: "#F0F8FF"
  style.stroke: "#4A90D9"
  style.font-size: 16

  R1c: Drafter {
    style.fill: "#4A90D9"
    style.font-color: "#FFFFFF"
  }
  P11: Entries Scraper {
    style.fill: "#7B68EE"
    style.font-color: "#FFFFFF"
  }
  E2: Supabase {
    style.fill: "#E67E22"
    style.font-color: "#FFFFFF"
  }
  P9: Chrome Extension {
    style.fill: "#7B68EE"
    style.font-color: "#FFFFFF"
  }
  P3c: Analytics Engine {
    style.fill: "#7B68EE"
    style.font-color: "#FFFFFF"
  }

  R1c -> P11: Visits entries page
  P11 -> E2: Writes roster data
  E2 -> P9: Reads portfolio
  P9 -> P3c: Computes exposure
  P3c -> R1c: Shows context in overlay
}

