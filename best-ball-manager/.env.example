# Best Ball Portfolio Manager — Environment Variables
#
# Copy this file to .env.local and fill in your values.
# The app works fully without any of these — local-only mode uses
# IndexedDB for storage and disables auth/subscription features.

# Supabase (enables auth + cloud storage)
# Get these from: https://supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Stripe (enables subscription payments)
# Get these from: https://dashboard.stripe.com/apikeys and Products
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_STRIPE_PRO_PRICE_ID=

# Sentry (enables error monitoring)
# Get your DSN from: https://sentry.io → Project Settings → Client Keys (DSN)
VITE_SENTRY_DSN=

# Email (SMTP)
# Transactional email (signup confirmation, password reset) is configured
# via the Supabase dashboard, not app-level env vars.
# Setup: Authentication > SMTP Settings in your Supabase project.
# Provider: Resend (smtp.resend.com:465, username "resend", password = API key)
# Templates: Authentication > Email Templates in Supabase dashboard.
