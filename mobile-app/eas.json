{
  "cli": {
    "version": ">= 14.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_APPLE_PRO_MONTHLY_PRODUCT_ID": "com.bestballexposures.app.pro.monthly",
        "EXPO_PUBLIC_APPLE_PRO_YEARLY_PRODUCT_ID": "com.bestballexposures.app.pro.yearly"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_APPLE_PRO_MONTHLY_PRODUCT_ID": "com.bestballexposures.app.pro.monthly",
        "EXPO_PUBLIC_APPLE_PRO_YEARLY_PRODUCT_ID": "com.bestballexposures.app.pro.yearly"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6791977736",
        "appleId": "heithoff.patrick@gmail.com"
      }
    }
  }
}
