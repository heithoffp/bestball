{
  "cli": {
    "version": ">= 14.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_APPLE_PRO_MONTHLY_PRODUCT_ID": "com.bestballexposures.app.pro.monthly",
        "EXPO_PUBLIC_APPLE_PRO_YEARLY_PRODUCT_ID": "com.bestballexposures.app.pro.yearly",
        "EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID": "",
        "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": ""
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_APPLE_PRO_MONTHLY_PRODUCT_ID": "com.bestballexposures.app.pro.monthly",
        "EXPO_PUBLIC_APPLE_PRO_YEARLY_PRODUCT_ID": "com.bestballexposures.app.pro.yearly",
        "EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID": "",
        "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": ""
      }
    }
  },
  "submit": {
    "production": {}
  }
}
