# Expo / React Native
node_modules/
.expo/
dist/
web-build/
# Anchored to the project root so these ignore ONLY the prebuild-generated
# native projects (mobile-app/ios, mobile-app/android) — NOT committed native
# source in nested dirs like modules/*/ios (local Expo module source). An
# unanchored `ios/` swallowed modules/bbe-draft-native/ios and kept the native
# module out of clean-room/CI builds (TASK-334).
/ios/
/android/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Build outputs (produced by `eas build --local`; the canonical copies live in
# GitHub Actions artifacts / App Store Connect, never in git — public repo).
*.ipa
*.app
*.dSYM.zip

# Metro
.metro-health-check*

# Env — EXPO_PUBLIC_ values are publishable, but keep local overrides out of git
.env.local

# macOS
.DS_Store
